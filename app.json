{
  "expo": {
    "name": "Dorm-Chores-Scheduler",
    "slug": "Dorm-Chores-Scheduler",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dormchoresscheduler",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.setap20252026.group7.teamc.dormchoresscheduler",
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "..."
      }
    },
    "android": {
      "package": "com.setap20252026.group7.teamc.dormchoresscheduler",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6b9575be-4652-45e8-ad1a-8350d90b16c7"
      }
    }
  }
}
